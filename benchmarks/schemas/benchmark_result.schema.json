{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlyDSL benchmark result row",
  "description": "One JSONL row per (shape_id, provider). Failed/unsupported/incorrect providers are KEPT, never silently dropped.",
  "type": "object",
  "required": ["run_id", "shape_id", "provider", "provider_detail", "candidate_commit", "gpu", "arch", "rocm_version", "correct", "warmup_iters", "repeat_iters", "benchmark_status"],
  "additionalProperties": true,
  "properties": {
    "run_id": {"type": "string"},
    "shape_id": {"type": "string"},
    "provider": {"type": "string", "enum": ["flydsl", "aiter", "aiter_triton", "aiter_ck", "aiter_asm", "ck", "triton", "gluon", "hipblaslt", "pytorch"]},
    "provider_detail": {"type": "string"},
    "candidate_commit": {"type": ["string", "null"]},
    "baseline_commit": {"type": ["string", "null"]},
    "gpu": {"type": ["string", "null"]},
    "arch": {"type": ["string", "null"]},
    "rocm_version": {"type": ["string", "null"]},
    "driver_version": {"type": ["string", "null"]},
    "correct": {"type": ["boolean", "null"]},
    "correctness_error": {"type": ["string", "null"]},
    "warmup_iters": {"type": "integer"},
    "repeat_iters": {"type": "integer"},
    "loops_per_measure": {"type": ["integer", "null"]},
    "median_us": {"type": ["number", "null"]},
    "mean_us": {"type": ["number", "null"]},
    "std_us": {"type": ["number", "null"]},
    "min_us": {"type": ["number", "null"]},
    "p10_us": {"type": ["number", "null"]},
    "p90_us": {"type": ["number", "null"]},
    "stable": {"type": ["boolean", "null"]},
    "effective_tflops": {"type": ["number", "null"]},
    "effective_gbps": {"type": ["number", "null"]},
    "workspace_bytes": {"type": ["integer", "null"]},
    "includes_allocation": {"type": "boolean"},
    "includes_layout_conversion": {"type": "boolean"},
    "includes_jit": {"type": "boolean"},
    "benchmark_status": {"type": "string", "enum": ["ok", "failed", "skipped", "oom", "unsupported", "incorrect", "not_configured"]},
    "skip_reason": {"type": ["string", "null"]},
    "profile_artifact": {"type": ["string", "null"]}
  }
}
